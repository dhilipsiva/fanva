# Auto-loads the Nix flake dev shell on `cd` (run `direnv allow` once).
# Uses nix-direnv's `use flake` when available (fast, cached); otherwise falls
# back to a portable form that works with stock direnv.
if has nix_direnv_version; then
  use flake
else
  watch_file flake.nix flake.lock
  eval "$(nix print-dev-env)"
fi
